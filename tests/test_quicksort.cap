# tests/test_quicksort.cap
quicksort = |arr| (
  if arr.len <= 1 then arr else (
    (|pivot|
      (|rest|
        (|left|
          (|right|
             left + [pivot] + right
          )(quicksort(rest |> filter(|x| x > pivot)))
        )(quicksort(rest |> filter(|x| x <= pivot)))
      )(1..arr.len |> map(|i| arr[i]))
    )(arr[0])
  )
)

println(quicksort([3, 1, 4, 1, 5, 9, 2, 6, 5, 3]))
