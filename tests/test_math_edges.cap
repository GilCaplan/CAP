# test_math_edges.cap -- edge cases in arithmetic
r1 = try(|| 1 % 0)
println("1 % 0 error: " + str(not r1["ok"]))   # true

r2 = try(|| 1 / 0)
println("1 / 0 error: " + str(not r2["ok"]))   # true

r3 = try(|| 0.0 / 0.0)
println("0.0 / 0.0 error: " + str(not r3["ok"]))   # true (division by zero)

println("2 ** 10 = " + str(2 ** 10))    # 1024.0
println("-5 % 3 = " + str(-5 % 3))      # -2
