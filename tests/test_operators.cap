# test_operators.cap — arithmetic, comparison, logical, and special operators

println("── Arithmetic ──")
println("3 + 4 =", 3 + 4)
println("10 - 3 =", 10 - 3)
println("6 * 7 =", 6 * 7)
println("10 / 4 =", 10 / 4)         # always float
println("10 % 3 =", 10 % 3)
println("2 ** 10 =", 2 ** 10)
println("-5 =", -5)
println("int/int = float:", type(10 / 2))

println("── Int/Float mixed ──")
println("1 + 0.5 =", 1 + 0.5)
println("3.0 - 1 =", 3.0 - 1)
println("2 * 1.5 =", 2 * 1.5)

println("── String ops ──")
println("hello + world =", "hello" + " world")
println("ab * 3 =", "ab" * 3)

println("── List concat ──")
a = [1, 2]
b = [3, 4]
println("[1,2]+[3,4] =", a + b)

println("── Comparison ──")
println("3 == 3:", 3 == 3)
println("3 != 4:", 3 != 4)
println("5 > 3:", 5 > 3)
println("3 < 5:", 3 < 5)
println("4 >= 4:", 4 >= 4)
println("4 <= 5:", 4 <= 5)
println("int==float 3==3.0:", 3 == 3.0)

println("── Logical ──")
println("true and true:", true and true)
println("true and false:", true and false)
println("false or true:", false or true)
println("not false:", not false)

println("── Short-circuit ──")
# Assignments are statements, not expressions in cap.
# Test short-circuit via return values: falsy `and` stops early,
# truthy `or` stops early — a would-be error expression is never reached.
println("false and X returns false:", (false and true) == false)
println("true or X returns true:", (true or false) == true)

println("── and/or return values ──")
println("1 and 2:", 1 and 2)
println("0 and 2:", 0 and 2)
println("0 or 2:", 0 or 2)
println("1 or 2:", 1 or 2)

println("── Null coalescing ──")
x = null
println("null ?? 42:", x ?? 42)
y = 10
println("10 ?? 42:", y ?? 42)
println("chained null??null??99:", null ?? null ?? 99)

println("── Missing map key returns null ──")
m = {"a": 1}
println("present key:", m["a"])
println("missing key:", m["b"])
println("missing ?? default:", m["b"] ?? 99)

println("── Ranges ──")
println("1..5 =", 1..5)
println("1..=5 =", 1..=5)
println("len(0..10) =", len(0..10))
